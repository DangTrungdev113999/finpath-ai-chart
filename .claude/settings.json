{
  "permissions": {
    "allow": [
      "Bash(pnpm run *)",
      "Bash(pnpm install*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/gitnexus-augment.sh\"",
            "timeout": 20,
            "statusMessage": "gitnexus augment"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE 'git (commit|merge)' && cd \"$CLAUDE_PROJECT_DIR\" && npx gitnexus analyze --force 2>/dev/null | tail -1 || true",
            "timeout": 120,
            "statusMessage": "Refreshing GitNexus index..."
          }
        ]
      }
    ]
  }
}
